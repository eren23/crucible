# Crucible environment configuration
# Copy to .env and fill in your values

# Weights & Biases (optional)
# WANDB_API_KEY=your_key
# WANDB_PROJECT=crucible
# WANDB_ENTITY=your_entity
# WANDB_MODE=online

# RunPod (required for crucible fleet provision)
# RUNPOD_API_KEY=your_key

# Anthropic (required for crucible research)
# ANTHROPIC_API_KEY=your_key
# RESEARCHER_MODEL=claude-sonnet-4-6-20250514
